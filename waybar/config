[{
    "height": 40,
    "spacing": 5,

    "modules-left": ["hyprland/workspaces", "custom/mullvad", "wireplumber", "mpris"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["cpu", "memory", "clock", "network", "bluetooth"],

    
    "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
        "1": "󰣇",
        "2": "󰈹",
        "3": "󰙯",
        "4": "󰍳",
        "5": "󰓓"
    },
    "persistent-workspaces": {
        "1": [],
        "2": [],
        "3": [],
        "4": [],
        "5": []
    }
},



    "hyprland/window": {
        "format": "{}",
        "max-length": 40,
        "separate-outputs": true
    },

    "mpris": {
        "format": "{player_icon} {title}",
        "format-paused": " {title}",
        "player-icons": {
            "default": "",
            "spotify": "",
            "firefox": "󰈹"
        },
        "max-length": 25,
        "on-click": "playerctl play-pause"
    },

    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "",
        "format-icons": ["", "", ""], 
        "on-click": "pavucontrol"
    },
    
    //"wireplumber#microphone": {
    //    "format": " {volume}%",
    //    "format-muted": "",
    //    "node-type": "Audio/Source"
    //}, 

    "custom/mullvad": {
        "format": "{}",
        "return-type": "json",
        "exec": "/home/h2obt/.config/waybar/mullvad-status.sh",
        "interval": 2,
        "on-click": "mullvad connect",
        "on-click-right": "mullvad disconnect",
        "on-click-middle": "mullvad-vpn"
    },

    "cpu": {
    "interval": 10,
    "format": " {icon} {usage}%",
    "format-icons": "",
    "on-click": "notify-send \"CPU Info\" \"$(sensors | grep 'Package id 0' | awk '{print $4}')\"",
    "tooltip": false,
    "exec": "echo -n ''",
    "exec-interval": 10
    },


    "memory": {
    "interval": 10,
    "format": "  {percentage}%",
    "on-click": "kitty --title btop-float htop",
    "tooltip": false
},


    "network": {
        "format-wifi": "󰖩",
        "format-ethernet": "",
        "format-disconnected": "󰈂",
        "on-click": "nm-connection-editor"
    },

    "bluetooth": {
        "format": " {status}",
        "format-connected": " {device_alias}",
        "on-click": "blueman-manager"
    },

    "clock": {
        "format": " {:%H:%M}",
        "format-alt": "   {:%d.%m.%Y}",
        "tooltip-format": "<tt>{calendar}</tt>"
    }
}]
